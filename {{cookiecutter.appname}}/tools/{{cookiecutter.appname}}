#!/bin/bash

set -e
VERSION="2.0.0"


function usage {
    cat <<EOF
Usage: $0 [options] COMMAND [command options]

Options:

    -i <inventory_path>     指定 Ansible 库存文件路径
    -h                      显示此帮助信息
    -e <ansible variables>  设置额外的变量，格式为 key=value 或 YAML/JSON
    -v                      增加 ansible-playbook 的详细程度
    -p <playbook>           运行指定的 playbook 文件，而不是默认文件
    -n                      模拟运行 - 不做任何更改
    -E                      回显命令 - 不实际运行
    -t <tags>               只运行带有指定标签的任务
    --version               显示版本信息
    -l, --limit <hosts>     限制在特定主机或组上运行

Commands:

    requirements            安装依赖
    deploy                  执行 _action 部署步骤
    config                  执行 _action 配置步骤
    remove                  执行 _action 移除步骤
    bootstrap-servers        初始化服务器
    prechecks               执行部署前检查
    postchecks              执行部署后检查
    pull                    从仓库拉取镜像
    check                   检查依赖
    genconfig               生成配置文件
    stop                    停止服务
    reconfigure             重新配置服务
    restart                 重启服务
    env                     打印当前配置的环境（库存/环境变量）
    ping [pattern]          对指定主机/组执行 Ansible ping(不是 ICMP ping)，默认为 all
    exec                    在指定的 Ansible 主机组上执行任意命令
    ssh                     使用 Ansible 库存凭证/连接 SSH 到主机（需要 Ansible 2.4 或更高版本）
    list                    列出库存中的主机（需要 Ansible 2.4 或更高版本）
    rescan                  将 SSH 主机密钥扫描到 \$HOME/.ssh/known_hosts
    help                    显示帮助信息

EOF
}

if [ -z "$1" ]; then
    usage
    exit 1
fi

if [ "$1" == "--help" ]; then
    usage
    exit 1
fi

if [[ "$1" == "--version" ]]; then
    echo "{{cookiecutter.appname}} $VERSION"
    exit 0
fi

function bash_completion {
cat <<EOF
-i
-p
-e
-h
-v
-t
requirements
deploy
config
remove
bootstrap-servers
prechecks
postchecks
pull
check
genconfig
stop
reconfigure
restart
ping
exec
ssh
list
rescan
env
help
EOF
}

# 从 Ansible 库存中获取主机配置的内部函数
function _ansible_config {
    _config=$(ansible-inventory -i "$inventory" --host "$1" 2>/dev/null | jq -r "$2 // empty" 2>/dev/null)
    if [ -n "$_config" ]; then
        echo "$_config"
    fi
}

# 使用 Ansible 库存信息 SSH 到主机的内部函数
function _ssh {
    local host=$1
    shift

    local ssh_user=$(ansible-inventory -i "$inventory" --host "$host" 2>/dev/null | jq -r '.ansible_ssh_user // empty')
    local ssh_host=$(ansible-inventory -i "$inventory" --host "$host" 2>/dev/null | jq -r '.ansible_host // empty')
    local ssh_port=$(ansible-inventory -i "$inventory" --host "$host" 2>/dev/null | jq -r '.ansible_ssh_port // empty')
    local ssh_key=$(ansible-inventory -i "$inventory" --host "$host" 2>/dev/null | jq -r '.ansible_ssh_private_key_file // empty')

    [ -z "$ssh_host" ] && ssh_host=$host
    [ -z "$ssh_user" ] && ssh_user="root"
    [ -z "$ssh_port" ] && ssh_port="22"

    local ssh_args="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
    [ -n "$ssh_key" ] && ssh_args="$ssh_args -i $ssh_key"

    if [ $# -eq 0 ]; then
        ssh $ssh_args -p $ssh_port $ssh_user@$ssh_host
    else
        ssh $ssh_args -p $ssh_port $ssh_user@$ssh_host "$@"
    fi
}

# 检查依赖的内部函数
function check_prerequisites {
    local missing_tools=()

    if ! command -v ansible >/dev/null 2>&1; then
        missing_tools+=("ansible")
    fi

    if ! command -v ansible-playbook >/dev/null 2>&1; then
        missing_tools+=("ansible-playbook")
    fi

    if ! command -v jq >/dev/null 2>&1; then
        missing_tools+=("jq")
    fi

    if [ ${#missing_tools[@]} -ne 0 ]; then
        echo "ERROR: Missing required tools: ${missing_tools[*]}"
        echo "Please install them first."
        exit 1
    fi
}

check_prerequisites

BASEDIR=${{{cookiecutter.appname}}_DIR:-/usr/share/{{cookiecutter.appname}}}
CONFIG_DIR=${{{cookiecutter.appname}}_CONFIG_DIR:-/etc/{{cookiecutter.appname}}}
VERBOSITY=
PLAYBOOK=${BASEDIR}/ansible/site.yml
ECHO=
EXTRA_OPTS=
TAGS=
INVENTORY=
LIMIT=

SHORT_OPTS=":hi:e:p:v?nEt:l:"
while getopts $SHORT_OPTS optchar; do
case "${optchar}" in
    i) INVENTORY="$OPTARG" ;;
    e) EXTRA_OPTS="$EXTRA_OPTS -e $OPTARG" ;;
    h) usage; exit 0 ;;
    p) PLAYBOOK=$OPTARG ;;
    v) VERBOSITY="$VERBOSITY --verbose" ;;
    n) EXTRA_OPTS="$EXTRA_OPTS --check" ;;
    t) TAGS="--tags $OPTARG" ;;
    E) ECHO=echo ;;
    l) LIMIT="--limit $OPTARG" ;;
    *) echo "Invalid option: -$OPTARG" >&2;  usage;   exit 1 ;;
esac
done

shift $((OPTIND-1))

if [ -z "$INVENTORY" ]; then
    INVENTORY="$CONFIG_DIR/hosts"
fi

if [ ! -f "$INVENTORY" ]; then
    echo "ERROR: $INVENTORY doesn't exist" >&2
    echo "Please copy config files: cp -rf $BASEDIR/etc_examples/{{cookiecutter.appname}} /etc/" >&2
    exit 1
fi

if [ -f "$CONFIG_DIR/env" ]; then
    source "$CONFIG_DIR/env"
fi

for f in "$CONFIG_DIR"/*.json "$CONFIG_DIR"/*.yml; do
    if [ -f "$f" ] && [ "$(basename $f)" != "extra-vars.yml" ]; then
        EXTRA_OPTS="$EXTRA_OPTS -e @$f"
    fi
done

if [ -f "$CONFIG_DIR/extra-vars.yml" ]; then
    EXTRA_OPTS="$EXTRA_OPTS -e @$CONFIG_DIR/extra-vars.yml"
fi

export CONFIG_PATH=$CONFIG_DIR

ACTION=$1
shift

run_playbook() {
    $ECHO ansible-playbook -i $INVENTORY $LIMIT $EXTRA_OPTS $VERBOSITY $TAGS "$@" $PLAYBOOK
}

case "$ACTION" in
    (deploy)
        run_playbook -e _action=deploy
        ;;
    (config)
        run_playbook -e _action=config
        ;;
    (remove)
        run_playbook -e _action=remove
        ;;
    (bootstrap-servers)
        run_playbook -e _action=bootstrap-servers
        ;;
    (prechecks)
        run_playbook -e _action=prechecks
        ;;
    (postchecks)
        run_playbook -e _action=postchecks
        ;;
    (pull)
        run_playbook -e _action=pull
        ;;
    (check)
        run_playbook -e _action=check
        ;;
    (genconfig)
        run_playbook -e _action=genconfig
        ;;
    (stop)
        run_playbook -e _action=stop
        ;;
    (reconfigure)
        run_playbook -e _action=reconfigure
        ;;
    (restart)
        run_playbook -e _action=restart
        ;;
    (requirements)
        $ECHO ansible-galaxy install -r ${BASEDIR}/requirements.yml -p ${BASEDIR}/ansible/roles-external "$@"
        ;;
    (ping)
        PING_TARGET="${1:-all}"
        shift
        $ECHO ansible -i $INVENTORY $LIMIT $PING_TARGET -m ping $VERBOSITY "$@"
        ;;
    (exec)
        ANSIBLE_GROUP=$1
        shift
        $ECHO ansible -i $INVENTORY $LIMIT "$ANSIBLE_GROUP" -m shell -a "$@"
        ;;
    (ssh)
        if [ -z "$1" ]; then
            echo "ERROR: No host specified"
            exit 1
        fi
        _ssh "$@"
        ;;
    (list)
        ansible-inventory -i $INVENTORY --list | jq -Mr '[._meta.hostvars | to_entries[] | {key: .key, value: .value.ansible_host}] | from_entries'
        ;;
    (rescan)
        HOSTS=$(ansible-inventory -i $INVENTORY --list | jq -Mr '._meta.hostvars | to_entries[] | select(.value.ansible_host != null) | .value.ansible_host')
        for h in $HOSTS; do
            ssh-keygen -R $h
            a=$(dig +short $h)
            if [ -n "$a" ]; then
                ssh-keygen -R $a
            fi
            ssh-keyscan -t rsa $h >> $HOME/.ssh/known_hosts
        done
        ;;
    (env)
        echo -e "$INVENTORY\n--"
        env | grep -E '^(KOLLA_|OS_|CONFIG_)' || true
        ;;
    (bash-completion)
        bash_completion
        exit 0
        ;;
    (help)
        usage
        ;;
    (*)
        if [ -z "$ACTION" ]; then
            echo -e "ERROR: No command specified\n"
        else
            echo -e "ERROR: '$ACTION' is invalid command\n"
        fi
        usage
        exit 2
        ;;
esac
